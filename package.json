{
    "name": "@bitstillery/mithril",
    "version": "3.0.1-AA",
    "description": "Mithril AA (AI Augmented) - Mithril + Signals, Store and SSR",
    "license": "MIT",
    "author": "Bitstillery",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bitstillery/mithril.git"
    },
    "files": [
        "*.ts",
        "*.d.ts",
        "ssrContext.ts",
        "signal.ts",
        "store.ts",
        "api/*.ts",
        "pathname/*.ts",
        "querystring/*.ts",
        "render/*.ts",
        "server/*.ts",
        "util/*.ts",
        "LICENSE",
        "README.md"
    ],
    "type": "module",
    "main": "./index.ts",
    "module": "./index.ts",
    "exports": {
        ".": {
            "import": "./index.ts",
            "default": "./index.ts"
        },
        "./browser": {
            "import": "./browser.ts",
            "default": "./browser.ts"
        },
        "./server": {
            "import": "./server.ts",
            "default": "./server.ts"
        },
        "./htm": {
            "import": "./htm.ts",
            "default": "./htm.ts"
        }
    },
    "scripts": {
        "lint": "bun run lint:ts",
        "lint:ts": "bun run lint:ts-format && bun run lint:ts-syntax && bun run lint:ts-types",
        "lint:ts-format": "oxfmt",
        "lint:ts-syntax": "oxlint -c .oxlintrc.json",
        "lint:ts-types": "tsgo --noEmit",
        "test": "bun test",
        "prepublishOnly": "bun run lint:ts",
        "pack:dry-run": "npm pack --dry-run"
    },
    "dependencies": {
        "htm": "^3.1.1"
    },
    "devDependencies": {
        "@types/bun": "^1.3.9",
        "@typescript/native-preview": "^7.0.0-dev.20260120.1",
        "oxfmt": "^0.32.0",
        "oxlint": "^1.30.0"
    }
}

{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "arrowParens": "always",
    "bracketSpacing": false,
    "endOfLine": "lf",
    "insertFinalNewline": true,
    "jsxSingleQuote": true,
    "printWidth": 130,
    "quoteProps": "as-needed",
    "semi": false,
    "singleQuote": true,
    "tabWidth": 4,
    "trailingComma": "all",
    "useTabs": false
}
